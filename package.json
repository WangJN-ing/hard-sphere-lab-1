{
  "name": "hard-sphere-lab",
  "version": "3.5.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop:dev": "vite build && electron .",
    "desktop:build": "vite build",
    "desktop:installer": "vite build && electron-builder --win nsis --x64",
    "desktop:portable": "vite build && electron-builder --win portable --x64",
    "exporter:bundle": "node scripts/bundleExporter.cjs",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.hardspherelab.desktop",
    "productName": "Hard Sphere Lab",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/exporter",
        "to": "exporter",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "tools/exporter/hsl_exporter.py",
        "to": "exporter/hsl_exporter.py"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hard Sphere Lab"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "lucide-react": "^0.292.0",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.18",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
